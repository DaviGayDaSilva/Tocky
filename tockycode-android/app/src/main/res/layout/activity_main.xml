<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="TockyCode"
            android:textSize="28sp"
            android:textColor="#00D9FF"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Professional AI Code Generator"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Language Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Language"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <Spinner
            android:id="@+id/languageSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="#2D2D2D"
            android:padding="8dp"
            android:layout_marginBottom="16dp" />

        <!-- Prompt Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Describe what you want to code"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/promptInput"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:hint="e.g., create a REST API with Flask, create a class for data processing, create a function to calculate fibonacci"
            android:textColor="#FFFFFF"
            android:textColorHint="#666666"
            android:background="#2D2D2D"
            android:gravity="top"
            android:padding="12dp"
            android:inputType="textMultiLine"
            android:layout_marginBottom="16dp" />

        <!-- Generate Button -->
        <Button
            android:id="@+id/generateButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Generate Code"
            android:textSize="16sp"
            android:textColor="#000000"
            android:backgroundTint="#00D9FF"
            android:layout_marginBottom="12dp" />

        <!-- Output Code -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Generated Code"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp">

            <TextView
                android:id="@+id/outputCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="200dp"
                android:minWidth="300dp"
                android:textColor="#00FF88"
                android:textSize="12sp"
                android:fontFamily="monospace"
                android:background="#1A1A1A"
                android:padding="16dp"
                android:visibility="gone"
                android:textIsSelectable="true" />

        </HorizontalScrollView>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <Button
                android:id="@+id/copyButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Copy"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444444"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/clearButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="Clear"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444444" />

        </LinearLayout>

        <!-- Footer -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="100% Free • Works Locally • No Internet Required"
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center" />

    </LinearLayout>

</ScrollView>